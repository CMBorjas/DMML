# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── AI Provider ──────────────────────────────────────────────────────────────
# "openai" (default) or "ollama" (local, no API key required)
AI_PROVIDER=openai

# Required when AI_PROVIDER=openai
OPENAI_API_KEY=sk-...

# Required when AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Database ─────────────────────────────────────────────────────────────────
# Leave unset for SQLite (local development)
# DATABASE_URL=postgresql://user:password@localhost/campaign_db

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
# Set to 1 to enable /debug/* routes (development only)
FLASK_DEBUG=0
